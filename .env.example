# ============================================================
# RouteTrackingT2 Addins Reports — Variables de Entorno
# Copia este archivo como .env.development o .env.production
# y completa los valores. NUNCA subas los archivos .env reales
# al repositorio (están en .gitignore).
# ============================================================

# URL base del API backend (sin slash al final)
VITE_API_BASE_URL=https://localhost:7268

# Clave de licencia Syncfusion EJ2
# Obtener en: https://www.syncfusion.com/account/my-account
VITE_SYNCFUSION_LICENSE_KEY=

# Familia tipográfica principal (se aplica como CSS custom property)
# Formato: "Nombre de la fuente, fuente alternativa, genérica"
VITE_APP_FONT_FAMILY="Segoe UI, Roboto, sans-serif"

# Tamaño de página por defecto para grillas/tablas Syncfusion (default: 10)
VITE_PAGE_SIZE=10

# URL base absoluta del deploy (necesario para addins MyGeotab).
# En dev se puede dejar vacío (usará '/'). En Vercel setear a la URL del proyecto.
# Ejemplo: https://addins-reports.vercel.app/
VITE_APP_BASE_URL=
